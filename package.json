{
  "name": "vulnerable-app",
  "version": "1.0.0",
  "description": "Intentionally vulnerable app for security testing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-vulnerabilities.js",
    "sonar": "sonar-scanner",
    "sonar:setup": "node scripts/setup-sonarqube.js",
    "lint": "eslint . --ext .js 2>/dev/null || true",
    "security-check": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "lodash": "3.10.1",
    "sqlite3": "^5.1.6",
    "body-parser": "^1.20.2",
    "express-rate-limit": "^6.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "sonar-scanner": "^3.1.0",
    "eslint": "^8.40.0"
  }
}
